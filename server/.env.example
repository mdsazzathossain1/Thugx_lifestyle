# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 PRODUCTION ENVIRONMENT VARIABLES - Thugx Lifestyle
# ═══════════════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: NEVER commit real values to git. Use deployment platform's secrets.
# - Vercel: Settings → Environment Variables
# - Railway: Variables tab
# - GitHub: Settings → Secrets and variables → Actions
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── FRONTEND URLS (Update these after deployment) ─────────────────────────────
# Change 'thugx-lifestyle' to your actual Vercel project name
CLIENT_URL=https://thugx-lifestyle.vercel.app
FRONTEND_URL=https://thugx-lifestyle.vercel.app

# ─── CORS CONFIGURATION ──────────────────────────────────────────────────────────
# Allow requests from your frontend domains
# Format: https://domain1.com,https://domain2.com
ALLOWED_ORIGINS=https://thugx-lifestyle.vercel.app,https://api.thugxlifestyle.com,https://thugxlifestyle.com

# ─── JWT CONFIGURATION (CRITICAL - Generate random strings!) ──────────────────────
# Generate at: https://generate-random.org or use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters for security
JWT_SECRET=generate-and-paste-32-char-random-string-here
JWT_ADMIN_SECRET=generate-and-paste-another-32-char-string-here
JWT_EXPIRE=7d

# ─── EMAIL SERVICE CONFIGURATION ────────────────────────────────────────────────
# Two options:
# Option 1: Gmail (quick setup, good for startups)
# Option 2: Mailgun/SendGrid (production recommended)

# ─ Option 1: Gmail Setup (Development/Startup) ──
EMAIL_SERVICE=gmail
EMAIL_USER=thugxlifestyle6@gmail.com
EMAIL_PASSWORD=ngqpoevvtzjnsqrg
EMAIL_FROM=noreply@thugxlifestyle.com

# ─ Option 2: Mailgun Setup (Production) - Uncomment to use ──
# EMAIL_SERVICE=custom
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@sandbox-xxxxx.mailgun.org
# SMTP_PASSWORD=your-mailgun-api-key-here
# EMAIL_FROM=noreply@thugxlifestyle.com

# ─── DATABASE CONFIGURATION ──────────────────────────────────────────────────────
# Option 1: JSON File Store (Default - included, no setup needed)
# Option 2: MongoDB Free Tier (for persistent data beyond platform limits)
#
# For MongoDB Atlas (free tier):
# 1. Sign up: https://www.mongodb.com/cloud/atlas
# 2. Create cluster
# 3. Get connection string
# 4. Uncomment below:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thugxlifestyle

# ─── ADMIN ACCOUNT (For initial setup) ──────────────────────────────────────────
# Change these values in production!
ADMIN_EMAIL=admin@thugxlifestyle.com
ADMIN_PASSWORD=ChangeMe123!@Secure

# ─── OPTIONAL: SECURITY ──────────────────────────────────────────────────────────
# Rate limiting configuration (handled in middleware)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════════════
# 📋 DEPLOYMENT CHECKLIST:
# ═══════════════════════════════════════════════════════════════════════════════
# [ ] Generate new JWT_SECRET (min 32 chars)
# [ ] Generate new JWT_ADMIN_SECRET (min 32 chars)
# [ ] Update CLIENT_URL with actual Vercel domain
# [ ] Update FRONTEND_URL with actual Vercel domain
# [ ] Configure email service (Gmail or Mailgun)
# [ ] Change default admin password
# [ ] Test email sending works
# [ ] Verify CORS settings allow your domain
# [ ] Set these in deployment platform (NOT in git!)
# [ ] Run security audit before going live
#
# ═══════════════════════════════════════════════════════════════════════════════
